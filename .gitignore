# OS
.DS_Store

# 의존성 (현재 없음, 향후 대비)
node_modules/

# 한컴 공식 명세 PDF (저작권 보유: 한글과컴퓨터) — 저장소에 포함하지 않음.
# 변환 규칙은 CONVERSION_RULES.md에 정리되어 있음.
*.pdf

# 크롬 확장 — 별도 저장소(minigu5/latex-to-hwp-extension)에서 관리
/chrome-extension/
/chrome-extension.crx

# 확장 프로그램 백업/배포 zip (chrome-extension 산출물 — 메인 저장소에 포함하지 않음)
*.zip

# 확장 프로그램 서브모듈/임시 흔적
/_ext_temp

# 개인 키 등 비밀 (확장 패키징 키 포함)
*.pem
